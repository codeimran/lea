{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend_react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/upload",
      "dest": "frontend_react/index.html"
    },
    {
       "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "frontend_react/index.html"
    }
  ]
}
